<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Do not trust user-installed CAs; Android system CAs only. -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
